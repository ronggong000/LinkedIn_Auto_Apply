{
  "manifest_version": 3,
  "name": "Seek Auto Apply Assistant",
  "version": "0.1.0",
  "description": "Assist Seek applications with AI-generated documents and autofill.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://www.seek.com.au/*"],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "src/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.seek.com.au/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
